# Turso Database (https://turso.tech — free tier, sign up with any email)
# Create a database, then copy the URL and token from the dashboard.
# To transfer: just share these two values with whoever needs access.
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Shared password for the GTM Planner (anyone with this password can access the site)
SITE_PASSWORD=your-team-password-here
